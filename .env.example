# Application
APP_ENV=local
APP_URL=http://localhost/mybrandplease
JWT_SECRET=change_this_super_secret_key_please
PRIVATE_UPLOAD_ROOT=storage/private_uploads

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mybrandplease
DB_USER=root
DB_PASS=

# Website form / meeting emails
MAIL_FROM_ADDRESS=website@example.com
MAIL_FROM_NAME=MyBrandPlease
MEETING_MAIL_ADMIN=admin@example.com
MEETING_MAIL_FROM=website@example.com
MEETING_GOOGLE_MEET_LINK=https://meet.google.com/

# Google Calendar API for automatic Google Meet links
# Scope needed: https://www.googleapis.com/auth/calendar
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=website@example.com
SMTP_PASSWORD=change_me
SMTP_ENCRYPTION=tls
SMTP_RELAX_TLS=0
MEETING_SMTP_HOST=smtp.example.com
MEETING_SMTP_PORT=587
MEETING_SMTP_USERNAME=website@example.com
MEETING_SMTP_PASSWORD=change_me
MEETING_SMTP_ENCRYPTION=tls
MEETING_SMTP_RELAX_TLS=0

# Stripe webhook, if used
STRIPE_WEBHOOK_SECRET=
